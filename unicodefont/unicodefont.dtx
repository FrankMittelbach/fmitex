\NewDocumentCommand\displaytable {O{} m o}{%
  \group_begin:
    \fontspec{#2}[#3]
    \keys_set:nn{@@}{#1}
%
    \begin{longtable}{@{}c@{\quad}*{16}{c}@{}}
      \@@_setup_header_footer:nn{#2}{#3}
      \@@_produce_table_rows:
      \@@_maybe_display_statistics:n{#2}
    \end{longtable}
  \group_end:
}
\NewDocumentCommand\displaysimpletable {O{} m o}{%
  \group_begin:
  \keys_set:nn{@@}{nostatistics,noheader,display-block=none,hexdigits=head+foot}
    \displaytable[#1]{#2}[#3]
  \group_end:
}
%    \end{macrocode}
%  \end{macro}
