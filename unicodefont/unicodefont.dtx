\prg_set_conditional:Npnn \@@_if_uchar_exists:n #1 { TF }
  {
    \tex_iffontchar:D \tex_font:D "#1 \scan_stop:
      \prg_return_true:
    \else:
      \prg_return_false:
    \fi:
  }


