%  \begin{macro}{\@@_setup_header_footer:nn}
%    
%    \begin{macrocode}
\cs_new:Npn \@@_setup_header_footer:nn #1#2{  % font name, features
  \bool_if:NT \l_@@_display_header_bool
       { \@@_format_table_title:nn{#1}{#2} 
         \\*[6pt]
       }
  \bool_if:NT \l_@@_header_hex_digits_bool
       { \@@_display_row_of_hex_digits: }
  \endfirsthead
  \bool_if:NT \l_@@_display_header_bool
       { \@@_format_table_cont:nn{#1}{#2} 
         \\*[6pt]
       }
  \bool_if:NT \l_@@_header_hex_digits_bool
       { \@@_display_row_of_hex_digits: }
  \endhead
  \bool_if:NT \l_@@_footer_hex_digits_bool
       { \@@_display_row_of_hex_digits: }
  \endfoot
  \bool_if:NT \l_@@_footer_hex_digits_bool
       {
         \@@_display_row_of_hex_digits:
       }
  \endlastfoot
}
%    \end{macrocode}
%  \end{macro}


\keys_define:nn {@@}
