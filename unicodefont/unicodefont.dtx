    & \@@_format_hex_digit:n{0} 
    & \@@_format_hex_digit:n{1} 
    & \@@_format_hex_digit:n{2} 
    & \@@_format_hex_digit:n{3} 
    & \@@_format_hex_digit:n{4} 
    & \@@_format_hex_digit:n{5} 
    & \@@_format_hex_digit:n{6} 
