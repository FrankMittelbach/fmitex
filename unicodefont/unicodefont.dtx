\cs_new:Npn \@@_setup_color: { \color{blue} }

\cs_new:Npn \@@_format_hex_digit:n #1 {
  \texttt{\scriptsize\@@_setup_color:  #1}
}

\cs_new:Npn \@@_format_row_title:n #1 {
  \texttt { \footnotesize \@@_setup_color:  U+#1 0 \, - \, #1 F }
}

\cs_new:Npn \@@_format_glyph:n #1 {
  \hbox_to_wd:nn {6pt} { \tex_hss:D \symbol{ " #1} \tex_hss:D }
}
\cs_new:Npn \@@_format_missing_glyph: {
  \hbox_to_wd:nn {6pt} { \tex_hss:D \@@_format_hex_digit:n{-} \tex_hss:D }
}


